# Copiar a .env. La URL de la API se inyecta por entorno (Amplify en prod).
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Google Analytics 4 (opcional). Si está vacío, no se carga ningún script de GA.
VITE_GA_MEASUREMENT_ID=

# reCAPTCHA v2 (casilla) — site key pública del formulario de contacto.
# Si está vacía, el formulario envía sin reCAPTCHA (solo dev/local).
VITE_RECAPTCHA_SITE_KEY=

# Token de verificación de Google Search Console (meta google-site-verification).
# Alternativa sin código: verificar por DNS TXT del dominio.
VITE_GSC_VERIFICATION=
